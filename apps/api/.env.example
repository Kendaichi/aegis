# Copy to apps/api/.env and fill in values. Required for upload → analyze → report flows:
# SUPABASE_URL, SUPABASE_KEY, SUPABASE_BUCKET, DATABASE_URL (see Supabase project settings).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
SUPABASE_BUCKET=videos
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

OLLAMA_HOST=http://localhost:11434

# VLM backend (see README "Wiring up the AI"):
#   mock — deterministic stub, no GPU/API (good for UI work)
#   real — Ollama on OLLAMA_HOST; VLM_MODEL must be a vision model you pulled (ollama list)
#   zai  — z.ai OpenAI-compatible API; set ZAI_API_KEY and a vision model name they support
VLM_MODE=mock
# Default below matches z.ai; for Ollama use your pulled tag, e.g. qwen2.5vl:7b or llama3.2-vision
VLM_MODEL=glm-4.6v-flash

# z.ai (only when VLM_MODE=zai) — verify model tag at https://docs.z.ai/
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Optional paths and sampling
UPLOAD_DIR=./uploads
FRAMES_DIR=./frames
FRAME_INTERVAL_SECONDS=2
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
