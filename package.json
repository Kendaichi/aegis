{
  "name": "aegis",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered disaster assessment desktop app (monorepo root)",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev:desktop": "npm --workspace apps/desktop run tauri dev",
    "build:desktop": "npm --workspace apps/desktop run tauri build",
    "dev:api": "echo \"Run: cd apps/api && uvicorn main:app --reload --port 8000\""
  }
}
