# Compose-level env — copy to .env and fill in. Full API variables: apps/api/.env.example

SUPABASE_URL=
SUPABASE_KEY=

# VLM backend: real (Ollama) | mock (canned responses) | zai (z.ai cloud)
VLM_MODE=mock
# For Ollama use a pulled vision model; for z.ai use their vision tag (e.g. glm-4.6v-flash)
VLM_MODEL=glm-4.6v-flash
FRAME_INTERVAL_SECONDS=2

# z.ai (only used when VLM_MODE=zai) — verify the model tag at https://docs.z.ai/
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
